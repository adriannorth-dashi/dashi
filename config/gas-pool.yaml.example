# sui-gas-pool configuration for Dashi Phase 2
# Copy this file to config/gas-pool.yaml, then run:
#   ./scripts/setup-sponsor-wallet.sh
# Documentation: https://github.com/MystenLabs/sui-gas-pool

signer-config:
  local:
    # Base64-encoded SuiKeyPair: [0x00 flag | 32-byte Ed25519 private key]
    # Run ./scripts/setup-sponsor-wallet.sh to populate this field.
    keypair: "REPLACE_WITH_BASE64_KEYPAIR"

rpc-host-ip: "0.0.0.0"
rpc-port: 9527
metrics-port: 9184

fullnode-url: "https://fullnode.testnet.sui.io:443"

gas-pool-config:
  redis:
    redis_url: "redis://127.0.0.1:6379"

coin-init-config:
  # Target balance per gas coin: 0.1 SUI = 100_000_000 MIST
  target-init-balance: 100000000
  # Re-check coin balances every 24 hours
  refresh-interval-sec: 86400

# Maximum SUI spent on gas per day: 1500 SUI = 1_500_000_000_000 MIST
daily-gas-usage-cap: 1500000000000

# Maximum gas budget per single request: 2 SUI = 2_000_000_000 MIST
max-sui-per-request: 2000000000

# Set true only for faucet use cases (same address sponsors itself) — not needed here
advanced-faucet-mode: false
