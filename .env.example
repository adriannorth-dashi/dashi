# ──────────────────────────────────────────────
# Dashi — Sui Gas Station  |  .env.example
# Copy to .env and fill in your values.
# Never commit .env to Git.
# ──────────────────────────────────────────────

# Sui network to operate on: testnet | mainnet
SUI_NETWORK=testnet

# Public Sui RPC endpoint (no key required for testnet/mainnet public nodes)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# API Key for authenticating requests to Dashi
# Generate a secure key:  openssl rand -hex 32
API_KEY=replace_with_a_secure_random_key

# HTTP port the Go server listens on
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://gasstation:secret@127.0.0.1:5432/gasstation

# Redis connection string
REDIS_URL=redis://127.0.0.1:6379

# ── Phase 2: sui-gas-pool (replaces Shinami) ───────────────────────────────

# Internal URL of the sui-gas-pool service (not exposed externally)
# Default matches the gaspool Docker service on host network
GASPOOL_URL=http://127.0.0.1:9527

# Bearer token for the gas-pool REST API.
# Must match GAS_STATION_AUTH in docker-compose.yml.
# Generate: openssl rand -hex 32
GASPOOL_AUTH_TOKEN=replace_with_a_secure_random_token

# ── Phase 1 only (no longer needed) ───────────────────────────────────────
# SHINAMI_GAS_STATION_KEY=us1_sui_testnet_YOUR_KEY_HERE
