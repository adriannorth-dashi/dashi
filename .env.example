# ──────────────────────────────────────────────
# Dashi — Sui Gas Station  |  .env.example
# Copy to .env and fill in your values.
# Never commit .env to Git.
# ──────────────────────────────────────────────

# ── Network ────────────────────────────────────────────────────────────────────

SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# For production, consider a dedicated RPC provider (better rate limits & SLA):
# Dwellir:   https://sui-mainnet.dwellir.com
# QuickNode: https://your-endpoint.quiknode.pro/your-key/

# ── Authentication ─────────────────────────────────────────────────────────────

# API Key for authenticating requests to Dashi.
# Generate: openssl rand -hex 32
API_KEY=replace_with_a_secure_random_key

# ── Server ────────────────────────────────────────────────────────────────────

PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgres://gasstation:secret@127.0.0.1:5432/gasstation

# ── Cache ─────────────────────────────────────────────────────────────────────

REDIS_URL=redis://127.0.0.1:6379

# ── sui-gas-pool ──────────────────────────────────────────────────────────────

# Internal URL of the sui-gas-pool service (default matches Docker Compose setup)
GASPOOL_URL=http://127.0.0.1:9527

# Bearer token for the gas-pool REST API.
# Must match GAS_STATION_AUTH in docker-compose.yml.
# Generate: openssl rand -hex 32
GASPOOL_AUTH_TOKEN=replace_with_a_secure_random_token

# Sponsor wallet address — printed by scripts/setup-sponsor-wallet.sh
SPONSOR_ADDRESS=0x

# ── Local testing (test.mjs) ──────────────────────────────────────────────────

# Sender wallet private key for node test.mjs — never used by the API server.
# This wallet pays nothing; gas is sponsored by the gas pool.
# Generate a dedicated test wallet: https://docs.sui.io/guides/developer/getting-started/get-address
SENDER_PRIVKEY=suiprivkey1...
