# ──────────────────────────────────────────────
# Dashi — Sui Gas Station  |  .env.example
# Copy to .env and fill in your values.
# Never commit .env to Git.
# ──────────────────────────────────────────────

# Sui network to operate on: testnet | mainnet
SUI_NETWORK=testnet

# Public Sui RPC endpoint (no key required for testnet/mainnet public nodes)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Shinami Gas Station API Key
# Sign up and get your free key at https://app.shinami.com
# Format: us1_sui_testnet_<hash>  (testnet)  or  us1_sui_mainnet_<hash>  (mainnet)
SHINAMI_GAS_STATION_KEY=us1_sui_testnet_YOUR_KEY_HERE

# API Key for authenticating requests to Dashi
# Generate a secure key:  openssl rand -hex 32
API_KEY=replace_with_a_secure_random_key

# HTTP port the Go server listens on inside Docker
PORT=8080

# PostgreSQL connection string
# In Docker Compose this matches the postgres service credentials below.
DATABASE_URL=postgres://gasstation:secret@postgres:5432/gasstation

# Redis connection string (used for rate limiting in Phase 2)
REDIS_URL=redis://redis:6379
