# ──────────────────────────────────────────────
# Dashi — Sui Gas Station  |  .env.example
# Copy to .env and fill in your values.
# Never commit .env to Git.
# ──────────────────────────────────────────────

# ── Network ────────────────────────────────────────────────────────────────────

SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# For production, consider a dedicated RPC provider (better rate limits & SLA):
# Dwellir:   https://sui-mainnet.dwellir.com
# QuickNode: https://your-endpoint.quiknode.pro/your-key/

# ── API server ─────────────────────────────────────────────────────────────────

PORT=8080

# Log level for the API server: debug | info | warn | error (default: info)
# Set to debug to see gas-pool request/response bodies.
LOG_LEVEL=info

# Rate limiting (backed by Redis)
# Per-API-key limit for GET endpoints (GET /v1/balance, GET /v1/execute/:id, GET /v1/sponsor/:digest).
RATE_LIMIT_PER_MINUTE=60
# Per-API-key limit for POST endpoints (POST /v1/sponsor, POST /v1/execute).
RATE_LIMIT_POST_PER_MINUTE=30
# Global cap across all callers combined.
RATE_LIMIT_GLOBAL_PER_MINUTE=500

# API Key for authenticating requests to Dashi.
# Generate: openssl rand -hex 32
API_KEY=replace_with_a_secure_random_key

# ── Database ──────────────────────────────────────────────────────────────────

POSTGRES_DB=gasstation
POSTGRES_USER=gasstation
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=replace_with_a_secure_db_password

# ── sui-gas-pool ──────────────────────────────────────────────────────────────

# Bearer token for the gas-pool REST API.
# Must match GAS_STATION_AUTH inside the gaspool container.
# Generate: openssl rand -hex 32
GASPOOL_AUTH_TOKEN=replace_with_a_secure_random_token

# Sponsor wallet address (0x + 64 hex chars)
SPONSOR_ADDRESS=0x

# Sponsor wallet private key — base64-encoded SuiKeyPair [0x00 flag | 32-byte Ed25519 key]
# Used by docker-compose.hub.yml to inject gas-pool.yaml without a separate file.
# Decode your suiprivkey: sui keytool decode-or-verify-tx --tx-bytes <suiprivkey>
# Then base64-encode the 33-byte result.
GASPOOL_KEYPAIR=replace_with_base64_keypair

# ── sui-gas-pool tuning (optional — defaults shown) ───────────────────────────

# Internal RPC and metrics ports (rarely need changing)
GASPOOL_RPC_PORT=9527
GASPOOL_METRICS_PORT=9184

# Target balance per gas coin in MIST (default: 0.1 SUI)
GASPOOL_TARGET_BALANCE=100000000

# How often to refresh coin balances in seconds (default: 24 h)
GASPOOL_REFRESH_INTERVAL=86400

# Maximum SUI spent on gas per day in MIST (default: 1500 SUI)
GASPOOL_DAILY_CAP=1500000000000

# Maximum gas budget per single request in MIST (default: 2 SUI)
GASPOOL_MAX_PER_REQUEST=2000000000

# ── Local testing (test.mjs) ──────────────────────────────────────────────────

# Sender wallet private key for node test.mjs — never used by the API server.
# This wallet pays nothing; gas is sponsored by the gas pool.
SENDER_PRIVKEY=suiprivkey1...
